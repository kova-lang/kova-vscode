{
  "scopeName": "source.kova",
  "patterns": [
    {
      "name": "comment.line.double-slash.kova",
      "match": "//.*$"
    },
    {
      "name": "string.quoted.double.kova",
      "begin": "\"",
      "end": "\""
    },
    {
      "name": "constant.numeric.kova",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    {
      "name": "keyword.control.kova",
      "match": "\\b(if|else|for|while)\\b"
    },
    {
      "name": "keyword.control.import.kova",
      "match": "\\b(import|export|from|into)\\b"
    },
    {
      "name": "keyword.other.kova",
      "match": "\\b(connect|using|respond|fn|let|insert|true|false)\\b"
    },
    {
      "name": "entity.name.function.kova",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
    },
    {
      "name": "entity.name.function.definition.kova",
      "match": "(?<=\\bfn\\s)([a-zA-Z_][a-zA-Z0-9_]*)"
    },
    {
      "name": "variable.other.object.key.kova",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=:)"
    },
    {
      "name": "variable.other.kova",
      "match": "(?<=\\blet\\s+)([a-zA-Z_][a-zA-Z0-9_]*)"
    },
    {
      "name": "variable.other.readwrite.kova",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  ]
}